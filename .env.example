NEXT_PUBLIC_APP_NAME=LaunchBeacon
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# App-wide platform/provider keys.
# These belong to the LaunchBeacon deployment, not individual customer accounts.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_LAUNCH_PRICE_ID=
STRIPE_GROWTH_PRICE_ID=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
PLAUSIBLE_SITE_ID=
PLAUSIBLE_API_KEY=
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_DEV=1
ENABLE_DEV_INBOX_SEED=0

# Internal testing bypasses for product crawl and Marketing Brief cooldowns.
# Comma-separated Supabase auth user IDs and/or email addresses. Leave empty in
# normal deployments; only trusted LaunchBeacon operator accounts belong here.
INTERNAL_ADMIN_USER_IDS=
INTERNAL_ADMIN_EMAILS=
CONNECTION_CREDENTIALS_ENCRYPTION_KEY=

# Legacy local publishing fallbacks only.
# Do not use these as the production multi-tenant connection model.
# Ghost, WordPress, and Webflow credentials should be collected per user in
# /settings/connections and stored encrypted in external_connections.
# This fallback is ignored in production even if set.
ENABLE_LEGACY_PUBLISHING_ENV_FALLBACK=0
GHOST_ADMIN_URL=
GHOST_ADMIN_API_KEY=
GHOST_API_VERSION=v6.0
WORDPRESS_SITE_URL=
WORDPRESS_USERNAME=
WORDPRESS_APPLICATION_PASSWORD=
WEBFLOW_API_TOKEN=
WEBFLOW_COLLECTION_ID=
WEBFLOW_BODY_FIELD_SLUG=body
WEBFLOW_SUMMARY_FIELD_SLUG=summary
WEBFLOW_META_TITLE_FIELD_SLUG=meta-title
WEBFLOW_META_DESCRIPTION_FIELD_SLUG=meta-description

# App-owned email/observability.
# RESEND currently powers app transactional mail and weekly digest delivery.
# User outreach sending should use per-user connections before live sending.
RESEND_API_KEY=
WEEKLY_DIGEST_FROM_EMAIL=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Legacy Supabase key aliases are still accepted by the code, but new projects
# should use NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY and SUPABASE_SECRET_KEY.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
